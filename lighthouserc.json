{
  "//": "Lighthouse CI config for FinFacts. LHCI self-serves dist/ (no separate server needed). Asserts accessibility + SEO + Core Web Vitals. The /map/ route ships a deck.gl/maplibre WebGL island (~285 KB gzipped lazy chunk by design, see DR-06/WI-10), so JS byte budgets are documented as warnings rather than hard errors to avoid failing the intentionally heavy map page; content pages are still held to strict category scores.",
  "ci": {
    "collect": {
      "staticDistDir": "./dist",
      "url": [
        "http://localhost/index.html",
        "http://localhost/explore/index.html",
        "http://localhost/species/carcharodon-carcharias/index.html",
        "http://localhost/lessons/biology-fundamentals/index.html",
        "http://localhost/map/index.html"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop"
      }
    },
    "assert": {
      "assertions": {
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:seo": ["error", { "minScore": 0.9 }],
        "categories:best-practices": ["warn", { "minScore": 0.9 }],
        "categories:performance": ["warn", { "minScore": 0.8 }],
        "first-contentful-paint": ["warn", { "maxNumericValue": 2000 }],
        "largest-contentful-paint": ["warn", { "maxNumericValue": 2500 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }],
        "total-blocking-time": ["warn", { "maxNumericValue": 300 }],
        "total-byte-weight": ["warn", { "maxNumericValue": 1600000 }],
        "uses-responsive-images": "warn",
        "modern-image-formats": "warn",
        "meta-description": "error",
        "document-title": "error",
        "html-has-lang": "error",
        "canonical": "warn"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
